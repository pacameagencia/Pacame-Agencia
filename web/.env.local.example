# ═══════════════════════════════════════════════════════════════════
# PACAME — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# 
# GENERADO AUTOMATICAMENTE desde web/lib/env/registry.ts
# NO editar a mano — cambios se pierden al regenerar.
# Run: node scripts/generate-env-example.mjs
# 
# Para ver status en vivo: https://pacameagencia.com/dashboard/env
# ═══════════════════════════════════════════════════════════════════

# ─── LLM / AI Models — Quality-first routing + budget guard                                                         

# Anthropic API key — tiers reasoning/titan/premium primary
# Provider: Anthropic
# Generate: https://console.anthropic.com/settings/keys
# Status: REQUIRED (production,preview,development)
CLAUDE_API_KEY=sk-ant-api03-...

# Nebius AI Studio — tiers standard/economy primary + fallback todo
# Provider: Nebius
# Generate: https://studio.nebius.com/settings/api-keys
# Status: REQUIRED (production,preview,development)
NEBIUS_API_KEY=eyJhbGci...

# Nebius endpoint override (default api.tokenfactory.nebius.com)
# Provider: Nebius
# Status: optional
NEBIUS_API_URL=https://api.tokenfactory.nebius.com/v1

# Gemma self-hosted VPS (Ollama) — economy tier primary
# Provider: PACAME VPS
# Status: optional
GEMMA_API_TOKEN=(bearer token del VPS)

# Gemma VPS endpoint (default gemma.pacameagencia.com)
# Provider: PACAME VPS
# Status: optional
GEMMA_API_URL=https://gemma.pacameagencia.com

# Google Gemini API — backup multimodal
# Provider: Google AI
# Generate: https://aistudio.google.com/app/apikey
# Status: optional
GEMINI_API_KEY=AIza...

# OpenAI — Whisper (transcripcion audio) + DALL-E 3 (imagenes)
# Provider: OpenAI
# Generate: https://platform.openai.com/api-keys
# Status: optional
OPENAI_API_KEY=sk-proj-...

# Google Vertex AI access token (si se usa Vertex)
# Provider: Google Cloud
# Generate: https://console.cloud.google.com/iam-admin/serviceaccounts
# Status: optional
VERTEX_ACCESS_TOKEN=ya29....

# Routing strategy: 'quality-first' (default) o 'cost-first'
# Provider: PACAME internal
# Status: REQUIRED (production)
LLM_STRATEGY=quality-first

# Budget tokens extended thinking Claude Opus (default 5000)
# Provider: PACAME internal
# Status: optional
LLM_THINKING_BUDGET_TOKENS=5000

# Cap EUR/dia tier reasoning. Al 80% warn, 100% auto-degrade
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_REASONING_EUR_DAILY=15

# Cap EUR/dia tier titan
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_TITAN_EUR_DAILY=20

# Cap EUR/dia tier premium
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_PREMIUM_EUR_DAILY=30

# Cap EUR/dia tier standard
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_STANDARD_EUR_DAILY=10

# Cap EUR/dia tier economy
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_ECONOMY_EUR_DAILY=3

# Tipo de cambio USD→EUR para budget guard (default 0.92)
# Provider: PACAME internal
# Status: optional
LLM_USD_TO_EUR=0.92

# Si 'true', salta todos los budget caps (emergencia)
# Provider: PACAME internal
# Status: optional
LLM_BUDGET_OVERRIDE=false

# ─── Database — Supabase + direct Postgres                                                    

# Supabase project URL (client-side visible)
# Provider: Supabase · public (NEXT_PUBLIC_)
# Generate: https://supabase.com/dashboard/project/_/settings/api
# Status: REQUIRED (production,preview,development)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase anon key — client browser (RLS protects data)
# Provider: Supabase · public (NEXT_PUBLIC_)
# Generate: https://supabase.com/dashboard/project/_/settings/api
# Status: REQUIRED (production,preview,development)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase service role — server-only, bypasses RLS
# Provider: Supabase
# Generate: https://supabase.com/dashboard/project/_/settings/api
# Status: REQUIRED (production,preview,development)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Postgres connection string (Session Pooler) — migrations script
# Provider: Supabase
# Generate: https://supabase.com/dashboard/project/_/settings/database
# Status: REQUIRED (development)
DATABASE_URL=postgresql://postgres.xxxxx:PWD@aws-1-eu-west-3.pooler.supabase.com:5432/postgres

# ─── Payments — Stripe                                                    

# Stripe secret — server-side checkout/refunds
# Provider: Stripe
# Generate: https://dashboard.stripe.com/apikeys
# Status: REQUIRED (production,preview,development)
STRIPE_SECRET_KEY=sk_live_...

# Stripe publishable — client-side tokenization
# Provider: Stripe · public (NEXT_PUBLIC_)
# Generate: https://dashboard.stripe.com/apikeys
# Status: REQUIRED (production,preview,development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret — valida events
# Provider: Stripe
# Generate: https://dashboard.stripe.com/webhooks
# Status: REQUIRED (production,preview)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Auth & Admin                                                        

# Admin dashboard password (HMAC-signed tokens derivan de esta)
# Provider: PACAME internal
# Status: REQUIRED (production,preview,development)
DASHBOARD_PASSWORD=una-password-fuerte

# Bearer token para proteger cron endpoints de Vercel scheduler
# Provider: PACAME internal
# Status: REQUIRED (production)
CRON_SECRET=random-32-chars

# ─── Messaging — Email, SMS, Voice, Telegram                                                   

# Resend — envio transaccional de emails
# Provider: Resend
# Generate: https://resend.com/api-keys
# Status: REQUIRED (production,preview,development)
RESEND_API_KEY=re_...

# Telegram bot — notifica Pablo (leads, errores, payments)
# Provider: Telegram BotFather
# Generate: https://t.me/BotFather
# Status: REQUIRED (production)
TELEGRAM_BOT_TOKEN=1234567:AAH...

# Chat ID de Pablo (destino notifications)
# Provider: Telegram
# Status: REQUIRED (production)
TELEGRAM_CHAT_ID=123456789

# Secret header para validar webhooks Telegram
# Provider: Telegram
# Status: optional
TELEGRAM_WEBHOOK_SECRET=random-secret

# Twilio Account SID — SMS
# Provider: Twilio
# Generate: https://console.twilio.com
# Status: optional
TWILIO_ACCOUNT_SID=AC...

# Twilio auth token
# Provider: Twilio
# Status: optional
TWILIO_AUTH_TOKEN=...

# Twilio voice phone (E.164)
# Provider: Twilio
# Status: optional
TWILIO_PHONE_NUMBER=+34722669381

# Twilio SMS phone (E.164)
# Provider: Twilio
# Status: optional
TWILIO_SMS_NUMBER=+34722669381

# Vapi — llamadas de voz IA
# Provider: Vapi
# Generate: https://dashboard.vapi.ai
# Status: optional
VAPI_API_KEY=...

# Vapi phone number ID (linked a Twilio)
# Provider: Vapi
# Status: optional
VAPI_PHONE_NUMBER_ID=...

# Voice server propio (VPS) — reemplaza Vapi si esta online
# Provider: PACAME VPS
# Status: optional
VOICE_SERVER_URL=https://voice.pacameagencia.com

# WhatsApp Business Phone ID (Meta Graph API)
# Provider: Meta for Developers
# Generate: https://developers.facebook.com/apps
# Status: optional
WHATSAPP_PHONE_ID=...

# WhatsApp Business access token (long-lived)
# Provider: Meta
# Status: optional
WHATSAPP_TOKEN=EAA...

# WhatsApp webhook verify token
# Provider: Meta
# Status: optional
WHATSAPP_VERIFY_TOKEN=pacame-wa-verify

# DarkRoom — token del bot @DarkRoomBot (BotFather, separado del PACAME)
# Provider: Telegram BotFather
# Generate: https://t.me/BotFather
# Status: optional
DARKROOM_TELEGRAM_BOT_TOKEN=1234567:AAH...

# DarkRoom — chat ID por defecto del bot (soporte humano u operaciones)
# Provider: Telegram
# Status: optional
DARKROOM_TELEGRAM_DEFAULT_CHAT_ID=123456789

# DarkRoom — secret header para validar webhooks Telegram (separado del PACAME)
# Provider: Telegram
# Status: optional
DARKROOM_TELEGRAM_WEBHOOK_SECRET=random-darkroom-secret

# DarkRoom — Phone ID del número WhatsApp Business dedicado (NO compartir con PACAME)
# Provider: Meta for Developers (BM Dark Room IO)
# Generate: https://developers.facebook.com/apps
# Status: optional
DARKROOM_WHATSAPP_PHONE_ID=...

# DarkRoom — long-lived WhatsApp token (legado). Prefiere DARKROOM_META_SYSTEM_USER_TOKEN.
# Provider: Meta
# Status: optional
DARKROOM_WHATSAPP_TOKEN=EAA...

# DarkRoom — webhook verify token (separado del PACAME)
# Provider: Meta
# Status: optional
DARKROOM_WHATSAPP_VERIFY_TOKEN=darkroom-wa-verify

# ─── Social Media — Instagram, Meta, LinkedIn, Buffer                                                      

# Meta Instagram App ID
# Provider: Meta for Developers
# Generate: https://developers.facebook.com/apps
# Status: optional
INSTAGRAM_APP_ID=...

# Meta Instagram App Secret (OAuth + HMAC webhooks)
# Provider: Meta
# Status: optional
INSTAGRAM_APP_SECRET=...

# Instagram Business long-lived access token
# Provider: Meta
# Status: optional
INSTAGRAM_ACCESS_TOKEN=IGQ...

# Instagram Business Account ID
# Provider: Meta
# Status: optional
INSTAGRAM_ACCOUNT_ID=17...

# Instagram webhook verify token
# Provider: Meta
# Status: optional
INSTAGRAM_VERIFY_TOKEN=pacame-ig-verify

# Facebook Page ID (multi-channel publishing)
# Provider: Meta
# Status: optional
META_PAGE_ID=...

# Facebook Page access token (legado, prefiere META_SYSTEM_USER_TOKEN)
# Provider: Meta
# Status: optional
META_PAGE_ACCESS_TOKEN=EAA...

# Meta System User token PERMANENTE (no expira) — cubre WhatsApp + IG + FB + Ads. Generar en business.facebook.com → System Users. Ver infra/docs/meta-system-user-token.md
# Provider: Meta Business Manager
# Generate: https://business.facebook.com/settings/system-users
# Status: optional
META_SYSTEM_USER_TOKEN=EAA...

# DarkRoom — System User token del Business Manager 'Dark Room IO'. NO compartir con PACAME (regla aislamiento Capa 3).
# Provider: Meta Business Manager (Dark Room IO)
# Generate: https://business.facebook.com/settings/system-users
# Status: optional
DARKROOM_META_SYSTEM_USER_TOKEN=EAA...

# DarkRoom — App ID de la app Meta dedicada DarkRoom
# Provider: Meta for Developers
# Generate: https://developers.facebook.com/apps
# Status: optional
DARKROOM_INSTAGRAM_APP_ID=...

# DarkRoom — App Secret de la app Meta DarkRoom (OAuth + HMAC webhooks)
# Provider: Meta
# Status: optional
DARKROOM_INSTAGRAM_APP_SECRET=...

# DarkRoom — long-lived IG token (legado). Prefiere DARKROOM_META_SYSTEM_USER_TOKEN.
# Provider: Meta
# Status: optional
DARKROOM_INSTAGRAM_ACCESS_TOKEN=IGQ...

# DarkRoom — Instagram Business Account ID (cuenta @darkroomstudio o similar)
# Provider: Meta
# Status: optional
DARKROOM_INSTAGRAM_ACCOUNT_ID=17...

# DarkRoom — verify token webhook IG (separado del PACAME)
# Provider: Meta
# Status: optional
DARKROOM_INSTAGRAM_VERIFY_TOKEN=darkroom-ig-verify

# ─── DarkRoom Community — Discord bot + cross-canal

# Discord Bot Token · BotFather → Developer Portal → Applications → Bot
# Provider: Discord
# Generate: https://discord.com/developers/applications
# Status: required (sin esto el bot no se conecta)
DARKROOM_DISCORD_BOT_TOKEN=MTAx...

# Discord Guild (server) ID · click derecho en el server → Copy ID (Developer Mode ON)
# Provider: Discord
# Status: required para role-sync
DARKROOM_DISCORD_GUILD_ID=123456789012345678

# HMAC compartido bot↔Vercel (mín 32 chars random)
# Generate: openssl rand -hex 32
# Status: required
DARKROOM_DISCORD_BOT_SECRET=random-32-chars-or-more

# HMAC para Stripe→Discord role-sync endpoint (mín 32 chars random)
# Generate: openssl rand -hex 32
# Status: required (sin esto Stripe no puede sincronizar roles)
DARKROOM_STRIPE_SYNC_SECRET=random-32-chars-or-more

# Discord Role IDs por tier (click derecho rol → Copy ID)
# Status: required para role-sync
DARKROOM_DISCORD_ROLE_LURKER_ID=
DARKROOM_DISCORD_ROLE_TRIAL_ID=
DARKROOM_DISCORD_ROLE_STARTER_ID=
DARKROOM_DISCORD_ROLE_PRO_ID=
DARKROOM_DISCORD_ROLE_STUDIO_ID=
DARKROOM_DISCORD_ROLE_CREW_ID=
DARKROOM_DISCORD_ROLE_CREW_VIP_ID=
DARKROOM_DISCORD_ROLE_FOUNDER_ID=

# Base URL Vercel deployment (para que el bot llame de vuelta)
# Status: optional, default https://darkroomcreative.cloud
DARKROOM_VERCEL_BASE=https://darkroomcreative.cloud

# Kill switch global · "true" pausa toda la comunidad (Escenario 4 master-playbook)
# Status: optional, default false
DARKROOM_COMMUNITY_PAUSE=false

# LinkedIn API access token
# Provider: LinkedIn Developers
# Generate: https://www.linkedin.com/developers/apps
# Status: optional
LINKEDIN_ACCESS_TOKEN=AQV...

# LinkedIn organization/company ID
# Provider: LinkedIn
# Status: optional
LINKEDIN_ORG_ID=12345678

# Buffer API token (multi-social scheduling)
# Provider: Buffer
# Generate: https://publish.buffer.com/app/account/apps
# Status: optional
BUFFER_ACCESS_TOKEN=1/...

# ─── Content & Design — Image gen                                                     

# Freepik Suite — imagen IA, upscale, remove bg, text-to-video
# Provider: Freepik
# Generate: https://www.freepik.com/api/dashboard
# Status: optional
FREEPIK_API_KEY=FPSX...

# Google Stitch — diseno UI con IA
# Provider: Google Stitch
# Status: optional
STITCH_API_KEY=...

