# n8n Webhook para formulario de leads
NEXT_PUBLIC_N8N_LEAD_WEBHOOK=https://n8n.pacameagencia.com/webhook/lead-form

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://kfmnllpscheodgxnutkw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════════
# LLM — Quality-first routing (Sprint 17)
# ═══════════════════════════════════════════════════════════════════
#
# Estrategia global de routing:
#   - quality-first (default): Claude Opus/Sonnet PRIMARY para
#     reasoning/titan/premium. Nebius PRIMARY para standard. Gemma PRIMARY
#     para economy. Claude como fallback de todo excepto economy donde
#     Nebius es el 2o y Claude el 3o.
#   - cost-first: Nebius PRIMARY para titan/premium tambien. Util en crons
#     batch de alto volumen no-critico.
LLM_STRATEGY=quality-first

# Claude API — NECESARIA para quality-first. Sin ella, todo cae a Nebius.
CLAUDE_API_KEY=

# Nebius AI Studio — NECESARIA como fallback + primary en standard/economy.
NEBIUS_API_KEY=
# NEBIUS_API_URL=https://api.tokenfactory.nebius.com/v1  # override si hace falta

# Gemma self-hosted en VPS (economy tier — gratis)
# GEMMA_API_TOKEN=
# GEMMA_API_URL=https://gemma.pacameagencia.com

# ── Override de modelos por tier (sin redeploy) ───────────────────────
# Si no se setean, se usan defaults del codigo.
# CLAUDE_MODEL_REASONING=claude-opus-4-6
# CLAUDE_MODEL_TITAN=claude-opus-4-6
# CLAUDE_MODEL_PREMIUM=claude-sonnet-4-6
# CLAUDE_MODEL_STANDARD=claude-haiku-4-5-20251001
# CLAUDE_MODEL_ECONOMY=claude-haiku-4-5-20251001
# NEBIUS_MODEL_REASONING=Qwen/Qwen3-Next-80B-A3B-Thinking-fast
# NEBIUS_MODEL_TITAN=moonshotai/Kimi-K2.5
# NEBIUS_MODEL_PREMIUM=Qwen/Qwen3-235B-A22B-Instruct-2507
# NEBIUS_MODEL_STANDARD=Qwen/Qwen3-Next-80B-A3B-Thinking-fast
# NEBIUS_MODEL_ECONOMY=Qwen/Qwen3-30B-A3B-Instruct-2507

# ── Extended thinking (reasoning tier — Claude Opus) ──────────────────
# Budget de tokens para chain-of-thought visible en DIOS strategist + audits.
# Mas alto = razonamiento mas profundo + mas caro.
LLM_THINKING_BUDGET_TOKENS=5000

# ── Budget caps diarios por tier (EUR) ────────────────────────────────
# 80% → notifyPablo warn + banner dashboard. 100% → auto-degrade al tier
# inferior. Override: LLM_BUDGET_OVERRIDE=true
LLM_BUDGET_REASONING_EUR_DAILY=15
LLM_BUDGET_TITAN_EUR_DAILY=20
LLM_BUDGET_PREMIUM_EUR_DAILY=30
LLM_BUDGET_STANDARD_EUR_DAILY=10
LLM_BUDGET_ECONOMY_EUR_DAILY=3
# LLM_BUDGET_OVERRIDE=false

# Tipo de cambio USD→EUR usado en budget-guard. Default 0.92.
# LLM_USD_TO_EUR=0.92
# ═══════════════════════════════════════════════════════════════════

