# Apify — scraping Google Maps (lead gen)
# Provider: Apify
# Generate: https://console.apify.com/account/integrations
# Status: REQUIRED (production)
APIFY_API_KEY=apify_api_...

# n8n webhook URL — lead form automation
# Provider: PACAME VPS n8n · public (NEXT_PUBLIC_)
# Status: REQUIRED (production)
NEXT_PUBLIC_N8N_LEAD_WEBHOOK=https://n8n.pacameagencia.com/webhook/lead-form

# Upstash Redis — rate limiting
# Provider: Upstash
# Generate: https://console.upstash.com/redis
# Status: optional
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io

# Upstash Redis token
# Provider: Upstash
# Status: optional
UPSTASH_REDIS_REST_TOKEN=AX...

# Sentry server DSN (error tracking)
# Provider: Sentry
# Generate: https://sentry.io/settings/projects/
# Status: optional
SENTRY_DSN=https://xxx@sentry.io/yyy

# Sentry client DSN (browser errors)
# Provider: Sentry · public (NEXT_PUBLIC_)
# Status: optional
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy

# Sentry auth (source maps upload en build)
# Provider: Sentry
# Status: optional
SENTRY_AUTH_TOKEN=sntrys_...

# Resend webhook Svix secret (open/click tracking lifecycle)
# Provider: Resend
# Generate: https://resend.com/webhooks
